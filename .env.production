# Firebase Configuration (Production)
# Replace with your production Firebase credentials
FIREBASE_API_KEY=YOUR_PRODUCTION_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PRODUCTION_PROJECT.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PRODUCTION_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PRODUCTION_PROJECT.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_PRODUCTION_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_PRODUCTION_APP_ID

# Environment
NODE_ENV=production
